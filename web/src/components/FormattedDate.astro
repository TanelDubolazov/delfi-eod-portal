---
import { DATE_FORMAT_OPTIONS, DATE_LOCALE, DATE_TIME_FORMAT_OPTIONS } from '../consts';

const { date, includeTime = false } = Astro.props;
const formatOptions = includeTime ? DATE_TIME_FORMAT_OPTIONS : DATE_FORMAT_OPTIONS;
---

<time datetime={date.toISOString()}>
	{date.toLocaleString(DATE_LOCALE, formatOptions)}
</time>
